# z.ai API key — get one at https://z.ai/manage-apikey/apikey-list
# The key never reaches the browser: the Vite dev server injects it into
# proxied requests. Leave empty to run the classic (non-AI) simulation.
ZAI_API_KEY=

# Optional: override the API base URL (default: https://api.z.ai/api/paas/v4)
# ZAI_BASE_URL=
